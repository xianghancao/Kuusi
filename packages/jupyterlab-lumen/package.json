{
  "name": "jupyterlab-lumen",
  "version": "0.1.0",
  "description": "Open Lumen mind map files and notebook mind map views inside JupyterLab",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "mindmap",
    "lumen"
  ],
  "license": "BSD-3-Clause",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "files": [
    "lib/**/*",
    "style/**/*"
  ],
  "scripts": {
    "build": "npm run build:kernel && npm run build:lib && npm run build:labextension:dev",
    "build:kernel": "npm run build --workspace=lumen-kernel",
    "build:lib": "tsc -p tsconfig.json",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "install:extension": "npm run build:kernel && npm run build:lib && npm run build:labextension:dev",
    "clean": "npm run clean:lib && rimraf jupyterlab_lumen/labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "tsc -w -p tsconfig.json",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.3.5",
    "@jupyterlab/apputils": "^4.3.5",
    "@jupyterlab/coreutils": "^6.3.5",
    "@jupyterlab/docregistry": "^4.3.5",
    "@jupyterlab/nbformat": "^4.3.5",
    "@jupyterlab/notebook": "^4.3.5",
    "@jupyterlab/services": "^7.3.5",
    "@jupyterlab/ui-components": "^4.3.5",
    "@lumino/widgets": "^2.5.0",
    "@tiptap/extension-code-block-lowlight": "^3.25.0",
    "@tiptap/extension-color": "^3.25.0",
    "@tiptap/extension-highlight": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/extension-mathematics": "^3.25.0",
    "@tiptap/extension-table": "^3.25.0",
    "@tiptap/extension-table-cell": "^3.25.0",
    "@tiptap/extension-table-header": "^3.25.0",
    "@tiptap/extension-table-row": "^3.25.0",
    "@tiptap/extension-task-item": "^3.25.0",
    "@tiptap/extension-task-list": "^3.25.0",
    "@tiptap/extension-text-style": "^3.25.0",
    "@tiptap/extension-underline": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "katex": "^0.16.47",
    "lowlight": "^3.3.0",
    "lumen-kernel": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.3.5",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_lumen/labextension"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  }
}
